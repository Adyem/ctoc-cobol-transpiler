       IDENTIFICATION DIVISION.
       PROGRAM-ID. SHOWCASE-TEXT.
       ENVIRONMENT DIVISION.
       DATA DIVISION.
       WORKING-STORAGE SECTION.
       01 TITLE-LENGTH PIC S9(9).
       01 LITERAL-LENGTH PIC S9(9).
       01 SUMMARY-LENGTH PIC S9(9).
       01 SHOWCASE-TEXT-TITLE.
          05 SHOWCASE-TEXT-TITLE-LEN PIC 9(4) COMP VALUE 0.
          05 SHOWCASE-TEXT-TITLE-CAP PIC 9(4) COMP VALUE 0.
          05 SHOWCASE-TEXT-TITLE-PTR USAGE POINTER VALUE NULL.
       01 SHOWCASE-TEXT-TITLE-BUF BASED PIC X(22).
       01 SHOWCASE-TEXT-SUMMARY.
          05 SHOWCASE-TEXT-SUMMARY-LEN PIC 9(4) COMP VALUE 0.
          05 SHOWCASE-TEXT-SUMMARY-CAP PIC 9(4) COMP VALUE 0.
          05 SHOWCASE-TEXT-SUMMARY-PTR USAGE POINTER VALUE NULL.
       01 SHOWCASE-TEXT-SUMMARY-BUF BASED PIC X(32).
       PROCEDURE DIVISION.
       SHOWCASE-TEXT.
           MOVE 0 TO SHOWCASE-TEXT-TITLE-LEN.
           IF SHOWCASE-TEXT-TITLE-CAP < 22
               IF SHOWCASE-TEXT-TITLE-PTR NOT = NULL
                   FREE SHOWCASE-TEXT-TITLE-PTR
               END-IF
               ALLOCATE 22 CHARACTERS RETURNING SHOWCASE-TEXT-TITLE-PTR
               SET ADDRESS OF SHOWCASE-TEXT-TITLE-BUF TO SHOWCASE-TEXT-TITLE-PTR
               COMPUTE SHOWCASE-TEXT-TITLE-CAP = 22
           END-IF.
           MOVE "CBL-C FEATURE SHOWCASE" TO SHOWCASE-TEXT-TITLE-BUF.
           COMPUTE SHOWCASE-TEXT-TITLE-LEN = 22.
           MOVE 0 TO SHOWCASE-TEXT-SUMMARY-LEN.
           IF SHOWCASE-TEXT-SUMMARY-CAP < 32
               IF SHOWCASE-TEXT-SUMMARY-PTR NOT = NULL
                   FREE SHOWCASE-TEXT-SUMMARY-PTR
               END-IF
               ALLOCATE 32 CHARACTERS RETURNING SHOWCASE-TEXT-SUMMARY-PTR
               SET ADDRESS OF SHOWCASE-TEXT-SUMMARY-BUF TO SHOWCASE-TEXT-SUMMARY-PTR
               COMPUTE SHOWCASE-TEXT-SUMMARY-CAP = 32
           END-IF.
           MOVE SPACES TO SHOWCASE-TEXT-SUMMARY-BUF.
           IF SHOWCASE-TEXT-TITLE-CAP < 1
               IF SHOWCASE-TEXT-TITLE-PTR NOT = NULL
                   FREE SHOWCASE-TEXT-TITLE-PTR
               END-IF
               ALLOCATE 1 CHARACTERS RETURNING SHOWCASE-TEXT-TITLE-PTR
               SET ADDRESS OF SHOWCASE-TEXT-TITLE-BUF TO SHOWCASE-TEXT-TITLE-PTR
               COMPUTE SHOWCASE-TEXT-TITLE-CAP = 1
           END-IF.
           SET ADDRESS OF SHOWCASE-TEXT-TITLE-BUF TO SHOWCASE-TEXT-TITLE-PTR
           DISPLAY SHOWCASE-TEXT-TITLE-BUF(1:SHOWCASE-TEXT-TITLE-LEN).
           COMPUTE TITLE-LENGTH = SHOWCASE-TEXT-TITLE-LEN.
           DISPLAY "Title length".
           DISPLAY TITLE-LENGTH.
           COMPUTE LITERAL-LENGTH = 13.
           DISPLAY "Literal length".
           DISPLAY LITERAL-LENGTH.
           IF SHOWCASE-TEXT-SUMMARY-CAP < 21
               IF SHOWCASE-TEXT-SUMMARY-PTR NOT = NULL
                   FREE SHOWCASE-TEXT-SUMMARY-PTR
               END-IF
               ALLOCATE 21 CHARACTERS RETURNING SHOWCASE-TEXT-SUMMARY-PTR
               SET ADDRESS OF SHOWCASE-TEXT-SUMMARY-BUF TO SHOWCASE-TEXT-SUMMARY-PTR
               COMPUTE SHOWCASE-TEXT-SUMMARY-CAP = 21
           END-IF.
           SET ADDRESS OF SHOWCASE-TEXT-SUMMARY-BUF TO SHOWCASE-TEXT-SUMMARY-PTR
           MOVE "UNDERWRITING + CLAIMS" TO SHOWCASE-TEXT-SUMMARY-BUF.
           MOVE 21 TO SHOWCASE-TEXT-SUMMARY-LEN.
           IF SHOWCASE-TEXT-SUMMARY-CAP < 1
               IF SHOWCASE-TEXT-SUMMARY-PTR NOT = NULL
                   FREE SHOWCASE-TEXT-SUMMARY-PTR
               END-IF
               ALLOCATE 1 CHARACTERS RETURNING SHOWCASE-TEXT-SUMMARY-PTR
               SET ADDRESS OF SHOWCASE-TEXT-SUMMARY-BUF TO SHOWCASE-TEXT-SUMMARY-PTR
               COMPUTE SHOWCASE-TEXT-SUMMARY-CAP = 1
           END-IF.
           SET ADDRESS OF SHOWCASE-TEXT-SUMMARY-BUF TO SHOWCASE-TEXT-SUMMARY-PTR
           DISPLAY SHOWCASE-TEXT-SUMMARY-BUF(1:SHOWCASE-TEXT-SUMMARY-LEN).
           DISPLAY "Summary length".
           COMPUTE SUMMARY-LENGTH = SHOWCASE-TEXT-SUMMARY-LEN.
           DISPLAY SUMMARY-LENGTH.
           MOVE 0 TO SHOWCASE-TEXT-SUMMARY-LEN.
           IF SHOWCASE-TEXT-SUMMARY-PTR NOT = NULL
               FREE SHOWCASE-TEXT-SUMMARY-PTR
           END-IF.
           SET SHOWCASE-TEXT-SUMMARY-PTR TO NULL.
           MOVE 0 TO SHOWCASE-TEXT-SUMMARY-CAP.
           MOVE 0 TO SHOWCASE-TEXT-TITLE-LEN.
           IF SHOWCASE-TEXT-TITLE-PTR NOT = NULL
               FREE SHOWCASE-TEXT-TITLE-PTR
           END-IF.
           SET SHOWCASE-TEXT-TITLE-PTR TO NULL.
           MOVE 0 TO SHOWCASE-TEXT-TITLE-CAP.
           GOBACK.

       END PROGRAM SHOWCASE-TEXT.
