       IDENTIFICATION DIVISION.
       PROGRAM-ID. SHOWCASE-SNAPSHOT.
       ENVIRONMENT DIVISION.
       DATA DIVISION.
       WORKING-STORAGE SECTION.
       01 RESERVE-TARGET PIC S9(9) VALUE 600000.
       01 NET-PREMIUM PIC S9(9) VALUE 480000.
       01 POLICIES-TOTAL PIC S9(9).
       01 CLAIMS-TOTAL PIC S9(9).
       01 INVESTIGATIONS-TOTAL PIC S9(9).
       01 LOSS-RATIO-TOTAL PIC S9(9).
       01 CLAIM-DELTA-TOTAL PIC S9(9).
       01 RESERVE-GAP-TOTAL PIC S9(9).
       01 SNAPSHOT-ID-TOTAL PIC S9(9).
       01 SNAPSHOT-LOAD-POLICIES PIC S9(9).
       01 SNAPSHOT-LOAD-CLAIMS PIC S9(9).
       01 SNAPSHOT-LOAD-INVESTIGATIONS PIC S9(9).
       01 SNAPSHOT-LOAD-PAYOUT PIC S9(9).
       01 SNAPSHOT.
       05 SNAPSHOT-IDENTIFIER PIC S9(9).
       05 SNAPSHOT-POLICIES-IN-FORCE-VALUE PIC S9(9).
       05 SNAPSHOT-CLAIMS-REPORTED-VALUE PIC S9(9).
       05 SNAPSHOT-OPEN-INVESTIGATIONS-VALUE PIC S9(9).
       05 SNAPSHOT-CLAIM-PAYOUT-VALUE PIC S9(9).
       05 SNAPSHOT-LABEL.
       10 SNAPSHOT-LABEL-LEN PIC 9(4) COMP VALUE 0.
       10 SNAPSHOT-LABEL-CAP PIC 9(4) COMP VALUE 0.
       10 SNAPSHOT-LABEL-PTR USAGE POINTER VALUE NULL.
       01 SNAPSHOT-LABEL-BUF BASED PIC X(16).
       PROCEDURE DIVISION.
       SHOWCASE-SNAPSHOT.
           COMPUTE SNAPSHOT-IDENTIFIER = 7.
           IF SNAPSHOT-LABEL-CAP < 4
               IF SNAPSHOT-LABEL-PTR NOT = NULL
                   FREE SNAPSHOT-LABEL-PTR
               END-IF
               ALLOCATE 4 CHARACTERS RETURNING SNAPSHOT-LABEL-PTR
               SET ADDRESS OF SNAPSHOT-LABEL-BUF TO SNAPSHOT-LABEL-PTR
               COMPUTE SNAPSHOT-LABEL-CAP = 4
           END-IF.
           SET ADDRESS OF SNAPSHOT-LABEL-BUF TO SNAPSHOT-LABEL-PTR
           MOVE "RISK" TO SNAPSHOT-LABEL-BUF.
           MOVE 4 TO SNAPSHOT-LABEL-LEN.
           COMPUTE SNAPSHOT-POLICIES-IN-FORCE-VALUE = 0.
           COMPUTE SNAPSHOT-CLAIMS-REPORTED-VALUE = 0.
           COMPUTE SNAPSHOT-OPEN-INVESTIGATIONS-VALUE = 0.
           COMPUTE SNAPSHOT-CLAIM-PAYOUT-VALUE = 0.
           IF SNAPSHOT-LABEL-CAP < 1
               IF SNAPSHOT-LABEL-PTR NOT = NULL
                   FREE SNAPSHOT-LABEL-PTR
               END-IF
               ALLOCATE 1 CHARACTERS RETURNING SNAPSHOT-LABEL-PTR
               SET ADDRESS OF SNAPSHOT-LABEL-BUF TO SNAPSHOT-LABEL-PTR
               COMPUTE SNAPSHOT-LABEL-CAP = 1
           END-IF.
           SET ADDRESS OF SNAPSHOT-LABEL-BUF TO SNAPSHOT-LABEL-PTR
           DISPLAY SNAPSHOT-LABEL-BUF(1:SNAPSHOT-LABEL-LEN).
           COMPUTE SNAPSHOT-LOAD-POLICIES = 1250.
           COMPUTE SNAPSHOT-LOAD-CLAIMS = 32.
           COMPUTE SNAPSHOT-LOAD-INVESTIGATIONS = 5.
           COMPUTE SNAPSHOT-LOAD-PAYOUT = 72000.
           COMPUTE SNAPSHOT-POLICIES-IN-FORCE-VALUE = SNAPSHOT-LOAD-POLICIES.
           COMPUTE SNAPSHOT-CLAIMS-REPORTED-VALUE = SNAPSHOT-LOAD-CLAIMS.
           COMPUTE SNAPSHOT-OPEN-INVESTIGATIONS-VALUE = SNAPSHOT-LOAD-INVESTIGATIONS.
           COMPUTE SNAPSHOT-CLAIM-PAYOUT-VALUE = SNAPSHOT-LOAD-PAYOUT.
           COMPUTE POLICIES-TOTAL = SNAPSHOT-POLICIES-IN-FORCE-VALUE.
           COMPUTE CLAIMS-TOTAL = SNAPSHOT-CLAIMS-REPORTED-VALUE.
           COMPUTE INVESTIGATIONS-TOTAL = SNAPSHOT-OPEN-INVESTIGATIONS-VALUE.
           COMPUTE LOSS-RATIO-TOTAL = SNAPSHOT-CLAIM-PAYOUT-VALUE * 100 / NET-PREMIUM.
           COMPUTE CLAIM-DELTA-TOTAL = SNAPSHOT-CLAIMS-REPORTED-VALUE - SNAPSHOT-OPEN-INVESTIGATIONS-VALUE.
           COMPUTE RESERVE-GAP-TOTAL = RESERVE-TARGET - NET-PREMIUM.
           DISPLAY "Snapshot id".
           COMPUTE SNAPSHOT-ID-TOTAL = SNAPSHOT-IDENTIFIER.
           DISPLAY SNAPSHOT-ID-TOTAL.
           DISPLAY "Policies in force".
           DISPLAY POLICIES-TOTAL.
           DISPLAY "Claims reported".
           DISPLAY CLAIMS-TOTAL.
           DISPLAY "Open investigations".
           DISPLAY INVESTIGATIONS-TOTAL.
           DISPLAY "Loss ratio percent".
           DISPLAY LOSS-RATIO-TOTAL.
           DISPLAY "Claim clearance delta".
           DISPLAY CLAIM-DELTA-TOTAL.
           DISPLAY "Reserve target gap".
           DISPLAY RESERVE-GAP-TOTAL.
           GOBACK.

       END PROGRAM SHOWCASE-SNAPSHOT.
