       IDENTIFICATION DIVISION.
       PROGRAM-ID. MAIN.
       ENVIRONMENT DIVISION.
       DATA DIVISION.
       WORKING-STORAGE SECTION.
       01 RESERVE-TARGET PIC S9(9) VALUE 600000.
       01 CLAIMS-PAID PIC S9(9) VALUE 2.
       01 METRICS.
       05 METRICS-NET-PREMIUM-VALUE PIC S9(9).
       05 METRICS-CLAIM-PAYOUT-VALUE PIC S9(9).
       01 NET-PREMIUM-TOTAL PIC S9(9).
       01 CLAIM-PAYOUT-TOTAL PIC S9(9).
       01 RESERVE-GAP-TOTAL PIC S9(9).
       01 LOSS-RATIO-TOTAL PIC S9(9).
       01 AVERAGE-CLAIM-TOTAL PIC S9(9).
       01 NOTE-LENGTH PIC S9(9).
       01 MAIN-NOTE.
          05 MAIN-NOTE-LEN PIC 9(4) COMP VALUE 32.
          05 MAIN-NOTE-BUF PIC X(32).
       PROCEDURE DIVISION.
MAIN.
           MOVE 0 TO MAIN-NOTE-LEN.
           MOVE SPACES TO MAIN-NOTE-BUF.
           COMPUTE METRICS-NET-PREMIUM-VALUE = 480000.
           COMPUTE METRICS-CLAIM-PAYOUT-VALUE = 72000.
           COMPUTE NET-PREMIUM-TOTAL = METRICS-NET-PREMIUM-VALUE.
           COMPUTE CLAIM-PAYOUT-TOTAL = METRICS-CLAIM-PAYOUT-VALUE.
           COMPUTE RESERVE-GAP-TOTAL = RESERVE-TARGET - METRICS-NET-PREMIUM-VALUE.
           COMPUTE LOSS-RATIO-TOTAL = METRICS-CLAIM-PAYOUT-VALUE * 100 / METRICS-NET-PREMIUM-VALUE.
           COMPUTE AVERAGE-CLAIM-TOTAL = METRICS-CLAIM-PAYOUT-VALUE / CLAIMS-PAID.
           DISPLAY "DAILY RISK METRICS".
           DISPLAY "Net premium written".
           DISPLAY NET-PREMIUM-TOTAL.
           DISPLAY "Claim payout total".
           DISPLAY CLAIM-PAYOUT-TOTAL.
           DISPLAY "Loss ratio percent".
           DISPLAY LOSS-RATIO-TOTAL.
           DISPLAY "Reserve target gap".
           DISPLAY RESERVE-GAP-TOTAL.
           DISPLAY "Average paid claim".
           DISPLAY AVERAGE-CLAIM-TOTAL.
           MOVE "Average claim stable" TO MAIN-NOTE-BUF.
           MOVE 20 TO MAIN-NOTE-LEN.
           DISPLAY MAIN-NOTE-BUF(1:MAIN-NOTE-LEN).
           COMPUTE NOTE-LENGTH = MAIN-NOTE-LEN.
           DISPLAY "Note length".
           DISPLAY NOTE-LENGTH.
           MOVE 0 TO MAIN-NOTE-LEN.
           MOVE SPACES TO MAIN-NOTE-BUF.
           STOP RUN.

       END PROGRAM MAIN.

