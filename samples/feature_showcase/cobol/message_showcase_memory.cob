       IDENTIFICATION DIVISION.
       PROGRAM-ID. SHOWCASE-MEMORY.
       ENVIRONMENT DIVISION.
       DATA DIVISION.
       WORKING-STORAGE SECTION.
       01 SCORES PIC S9(9) OCCURS 3 TIMES.
       01 SLOT PIC S9(9).
       01 SELECTED-SCORE PIC S9(9).
       01 POINTER-SCORE PIC S9(9).
       01 SCORE-CURSOR USAGE POINTER VALUE NULL.
       01 SCORE-HEAP USAGE POINTER VALUE NULL.
       01 STATUS-BUFFER USAGE POINTER VALUE NULL.
       01 GRADE PIC X(1).
       01 SCRATCH USAGE POINTER VALUE NULL.
       01 CBLC-PTR-CURSOR USAGE POINTER VALUE NULL.
       01 CBLC-PTR-OFFSET PIC S9(9) VALUE 0.
       01 CBLC-PTR-CHAR BASED PIC X.
       01 CBLC-PTR-INT BASED PIC S9(9).
       01 CBLC-PTR-INT-PTR BASED USAGE POINTER.
       PROCEDURE DIVISION.
       SHOWCASE-MEMORY.
           COMPUTE SCORES(1) = 74.
           COMPUTE SCORES(2) = 88.
           COMPUTE SCORES(3) = 91.
           COMPUTE SLOT = 1.
           COMPUTE SELECTED-SCORE = SCORES(SLOT + 1).
           DISPLAY "Selected score".
           DISPLAY SELECTED-SCORE.
           ALLOCATE 16 CHARACTERS RETURNING SCRATCH.
           FREE SCRATCH.
           ALLOCATE 12 CHARACTERS RETURNING SCORE-HEAP.
           SET CBLC-PTR-CURSOR TO SCORE-HEAP.
           SET ADDRESS OF CBLC-PTR-INT TO CBLC-PTR-CURSOR.
           COMPUTE CBLC-PTR-INT = SELECTED-SCORE.
           SET CBLC-PTR-CURSOR TO SCORE-HEAP.
           COMPUTE CBLC-PTR-OFFSET = 1 * 4.
           SET CBLC-PTR-CURSOR UP BY CBLC-PTR-OFFSET.
           SET ADDRESS OF CBLC-PTR-INT TO CBLC-PTR-CURSOR.
           COMPUTE CBLC-PTR-INT = SELECTED-SCORE + 4.
           SET SCORE-CURSOR TO SCORE-HEAP.
           COMPUTE CBLC-PTR-OFFSET = 1 * 4.
           SET SCORE-CURSOR UP BY CBLC-PTR-OFFSET.
           SET CBLC-PTR-CURSOR TO SCORE-CURSOR.
           SET ADDRESS OF CBLC-PTR-INT TO CBLC-PTR-CURSOR.
           COMPUTE POINTER-SCORE = CBLC-PTR-INT.
           DISPLAY "Adjusted score".
           DISPLAY POINTER-SCORE.
           FREE SCORE-HEAP.
           ALLOCATE 4 CHARACTERS RETURNING STATUS-BUFFER.
           SET CBLC-PTR-CURSOR TO STATUS-BUFFER.
           SET ADDRESS OF CBLC-PTR-CHAR TO CBLC-PTR-CURSOR.
           MOVE "A" TO CBLC-PTR-CHAR.
           SET CBLC-PTR-CURSOR TO STATUS-BUFFER.
           SET ADDRESS OF CBLC-PTR-CHAR TO CBLC-PTR-CURSOR.
           MOVE CBLC-PTR-CHAR TO GRADE.
           DISPLAY "Grade".
           DISPLAY GRADE.
           FREE STATUS-BUFFER.
           SET SCORE-CURSOR TO ADDRESS OF SELECTED-SCORE.
           SET CBLC-PTR-CURSOR TO SCORE-CURSOR.
           SET ADDRESS OF CBLC-PTR-INT TO CBLC-PTR-CURSOR.
           COMPUTE POINTER-SCORE = CBLC-PTR-INT.
           DISPLAY "Score by address".
           DISPLAY POINTER-SCORE.
           GOBACK.

       END PROGRAM SHOWCASE-MEMORY.

