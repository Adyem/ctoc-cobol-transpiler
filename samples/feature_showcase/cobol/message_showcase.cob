       IDENTIFICATION DIVISION.
       PROGRAM-ID. MAIN.
       ENVIRONMENT DIVISION.
       DATA DIVISION.
       WORKING-STORAGE SECTION.
       01 RENEWALREPORT-LOAD-POLICIES PIC S9(9).
       01 RENEWALREPORT-LOAD-CLAIMS PIC S9(9).
       01 RENEWALREPORT-LOAD-INVESTIGATIONS PIC S9(9).
       01 RENEWALREPORT-LOAD-PAID PIC S9(9).
       01 STAGECOUNTER-ADD-DELTA PIC S9(9).
       01 REVIEW-STEP.
       05 REVIEW-STEP-VALUE PIC S9(9).
       PROCEDURE DIVISION.
       MAIN.
           COMPUTE REVIEW-STEP-VALUE = 0.
           COMPUTE STAGECOUNTER-ADD-DELTA = 1.
           COMPUTE REVIEW-STEP-VALUE = REVIEW-STEP-VALUE + STAGECOUNTER-ADD-DELTA.
           DISPLAY "CBL-C STARTER SHOWCASE".
           CALL 'SHOWCASE-TEXT'.
           COMPUTE STAGECOUNTER-ADD-DELTA = 1.
           COMPUTE REVIEW-STEP-VALUE = REVIEW-STEP-VALUE + STAGECOUNTER-ADD-DELTA.
           CALL 'SHOWCASE-PORTFOLIO'.
           COMPUTE STAGECOUNTER-ADD-DELTA = 1.
           COMPUTE REVIEW-STEP-VALUE = REVIEW-STEP-VALUE + STAGECOUNTER-ADD-DELTA.
           CALL 'SHOWCASE-MEMORY'.
           DISPLAY "Modules".
           DISPLAY REVIEW-STEP-VALUE.
           DISPLAY "SHOWCASE READY".
           STOP RUN.

       END PROGRAM MAIN.

