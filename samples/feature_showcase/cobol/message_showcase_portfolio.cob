       IDENTIFICATION DIVISION.
       PROGRAM-ID. SHOWCASE-PORTFOLIO.
       ENVIRONMENT DIVISION.
       DATA DIVISION.
       WORKING-STORAGE SECTION.
       01 RESERVE-TARGET PIC S9(9) VALUE 600000.
       01 EARNED-PREMIUM PIC S9(9) VALUE 480000.
       01 RENEWALREPORT-LOAD-POLICIES PIC S9(9).
       01 RENEWALREPORT-LOAD-CLAIMS PIC S9(9).
       01 RENEWALREPORT-LOAD-INVESTIGATIONS PIC S9(9).
       01 RENEWALREPORT-LOAD-PAID PIC S9(9).
       01 BOOK.
       05 BOOK-UNDERWRITING.
       10 BOOK-UNDERWRITING-NAME.
       15 BOOK-UNDERWRITING-NAME-LEN PIC 9(4) COMP VALUE 0.
       15 BOOK-UNDERWRITING-NAME-CAP PIC 9(4) COMP VALUE 0.
       15 BOOK-UNDERWRITING-NAME-PTR USAGE POINTER VALUE NULL.
       10 BOOK-UNDERWRITING-OPEN-ITEMS PIC S9(9).
       10 BOOK-UNDERWRITING-CLOSED-ITEMS PIC S9(9).
       05 BOOK-CLAIMS.
       10 BOOK-CLAIMS-NAME.
       15 BOOK-CLAIMS-NAME-LEN PIC 9(4) COMP VALUE 0.
       15 BOOK-CLAIMS-NAME-CAP PIC 9(4) COMP VALUE 0.
       15 BOOK-CLAIMS-NAME-PTR USAGE POINTER VALUE NULL.
       10 BOOK-CLAIMS-OPEN-ITEMS PIC S9(9).
       10 BOOK-CLAIMS-CLOSED-ITEMS PIC S9(9).
       01 BOOK-UNDERWRITING-NAME-BUF BASED PIC X(16).
       01 BOOK-CLAIMS-NAME-BUF BASED PIC X(16).
       01 RISK-REVIEW.
       05 RISK-REVIEW-IDENTIFIER PIC S9(9).
       05 RISK-REVIEW-TAG.
       10 RISK-REVIEW-TAG-LEN PIC 9(4) COMP VALUE 0.
       10 RISK-REVIEW-TAG-CAP PIC 9(4) COMP VALUE 0.
       10 RISK-REVIEW-TAG-PTR USAGE POINTER VALUE NULL.
       05 RISK-REVIEW-POLICY-COUNT PIC S9(9).
       05 RISK-REVIEW-CLAIM-COUNT PIC S9(9).
       05 RISK-REVIEW-INVESTIGATION-COUNT PIC S9(9).
       05 RISK-REVIEW-PAID-CLAIMS PIC S9(9).
       01 RISK-REVIEW-TAG-BUF BASED PIC X(16).
       01 ACTIVE-DESKS PIC S9(9).
       01 OUTPUT-REPORT-ID PIC S9(9).
       01 POLICIES-TOTAL PIC S9(9).
       01 NET-CLAIMS-TOTAL PIC S9(9).
       01 LOSS-RATIO-TOTAL PIC S9(9).
       01 RESERVE-GAP-TOTAL PIC S9(9).
       01 IMPORTED-TOTAL PIC S9(9).
       01 UNDERWRITING-OPEN PIC S9(9).
       01 UNDERWRITING-CLOSED PIC S9(9).
       PROCEDURE DIVISION.
       SHOWCASE-PORTFOLIO.
           COMPUTE RISK-REVIEW-IDENTIFIER = 7.
           IF RISK-REVIEW-TAG-CAP < 4
               IF RISK-REVIEW-TAG-PTR NOT = NULL
                   FREE RISK-REVIEW-TAG-PTR
               END-IF
               ALLOCATE 4 CHARACTERS RETURNING RISK-REVIEW-TAG-PTR
               SET ADDRESS OF RISK-REVIEW-TAG-BUF TO RISK-REVIEW-TAG-PTR
               COMPUTE RISK-REVIEW-TAG-CAP = 4
           END-IF.
           SET ADDRESS OF RISK-REVIEW-TAG-BUF TO RISK-REVIEW-TAG-PTR
           MOVE "RISK" TO RISK-REVIEW-TAG-BUF.
           MOVE 4 TO RISK-REVIEW-TAG-LEN.
           COMPUTE RISK-REVIEW-POLICY-COUNT = 0.
           COMPUTE RISK-REVIEW-CLAIM-COUNT = 0.
           COMPUTE RISK-REVIEW-INVESTIGATION-COUNT = 0.
           COMPUTE RISK-REVIEW-PAID-CLAIMS = 0.
           IF BOOK-UNDERWRITING-NAME-CAP < 12
               IF BOOK-UNDERWRITING-NAME-PTR NOT = NULL
                   FREE BOOK-UNDERWRITING-NAME-PTR
               END-IF
               ALLOCATE 12 CHARACTERS RETURNING BOOK-UNDERWRITING-NAME-PTR
               SET ADDRESS OF BOOK-UNDERWRITING-NAME-BUF TO BOOK-UNDERWRITING-NAME-PTR
               COMPUTE BOOK-UNDERWRITING-NAME-CAP = 12
           END-IF.
           SET ADDRESS OF BOOK-UNDERWRITING-NAME-BUF TO BOOK-UNDERWRITING-NAME-PTR
           MOVE "UNDERWRITING" TO BOOK-UNDERWRITING-NAME-BUF.
           MOVE 12 TO BOOK-UNDERWRITING-NAME-LEN.
           COMPUTE BOOK-UNDERWRITING-OPEN-ITEMS = 19.
           COMPUTE BOOK-UNDERWRITING-CLOSED-ITEMS = 23.
           IF BOOK-CLAIMS-NAME-CAP < 6
               IF BOOK-CLAIMS-NAME-PTR NOT = NULL
                   FREE BOOK-CLAIMS-NAME-PTR
               END-IF
               ALLOCATE 6 CHARACTERS RETURNING BOOK-CLAIMS-NAME-PTR
               SET ADDRESS OF BOOK-CLAIMS-NAME-BUF TO BOOK-CLAIMS-NAME-PTR
               COMPUTE BOOK-CLAIMS-NAME-CAP = 6
           END-IF.
           SET ADDRESS OF BOOK-CLAIMS-NAME-BUF TO BOOK-CLAIMS-NAME-PTR
           MOVE "CLAIMS" TO BOOK-CLAIMS-NAME-BUF.
           MOVE 6 TO BOOK-CLAIMS-NAME-LEN.
           COMPUTE BOOK-CLAIMS-OPEN-ITEMS = 32.
           COMPUTE BOOK-CLAIMS-CLOSED-ITEMS = 27.
           COMPUTE ACTIVE-DESKS = 2.
           COMPUTE UNDERWRITING-OPEN = BOOK-UNDERWRITING-OPEN-ITEMS.
           COMPUTE UNDERWRITING-CLOSED = BOOK-UNDERWRITING-CLOSED-ITEMS.
           COMPUTE RENEWALREPORT-LOAD-POLICIES = 1250.
           COMPUTE RENEWALREPORT-LOAD-CLAIMS = 32.
           COMPUTE RENEWALREPORT-LOAD-INVESTIGATIONS = 5.
           COMPUTE RENEWALREPORT-LOAD-PAID = 72000.
           COMPUTE RISK-REVIEW-POLICY-COUNT = RENEWALREPORT-LOAD-POLICIES.
           COMPUTE RISK-REVIEW-CLAIM-COUNT = RENEWALREPORT-LOAD-CLAIMS.
           COMPUTE RISK-REVIEW-INVESTIGATION-COUNT = RENEWALREPORT-LOAD-INVESTIGATIONS.
           COMPUTE RISK-REVIEW-PAID-CLAIMS = RENEWALREPORT-LOAD-PAID.
           IF RISK-REVIEW-TAG-CAP < 1
               IF RISK-REVIEW-TAG-PTR NOT = NULL
                   FREE RISK-REVIEW-TAG-PTR
               END-IF
               ALLOCATE 1 CHARACTERS RETURNING RISK-REVIEW-TAG-PTR
               SET ADDRESS OF RISK-REVIEW-TAG-BUF TO RISK-REVIEW-TAG-PTR
               COMPUTE RISK-REVIEW-TAG-CAP = 1
           END-IF.
           SET ADDRESS OF RISK-REVIEW-TAG-BUF TO RISK-REVIEW-TAG-PTR
           DISPLAY RISK-REVIEW-TAG-BUF(1:RISK-REVIEW-TAG-LEN).
           COMPUTE OUTPUT-REPORT-ID = RISK-REVIEW-IDENTIFIER.
           COMPUTE POLICIES-TOTAL = RISK-REVIEW-POLICY-COUNT.
           COMPUTE NET-CLAIMS-TOTAL = RISK-REVIEW-CLAIM-COUNT - RISK-REVIEW-INVESTIGATION-COUNT.
           COMPUTE LOSS-RATIO-TOTAL = RISK-REVIEW-PAID-CLAIMS * 100 / EARNED-PREMIUM.
           COMPUTE RESERVE-GAP-TOTAL = RESERVE-TARGET - EARNED-PREMIUM.
           COMPUTE IMPORTED-TOTAL = UNDERWRITING-OPEN + UNDERWRITING-CLOSED.
           DISPLAY "Report id".
           DISPLAY OUTPUT-REPORT-ID.
           DISPLAY "Policies".
           DISPLAY POLICIES-TOTAL.
           DISPLAY "Net claims".
           DISPLAY NET-CLAIMS-TOTAL.
           DISPLAY "Loss ratio".
           DISPLAY LOSS-RATIO-TOTAL.
           DISPLAY "Reserve gap".
           DISPLAY RESERVE-GAP-TOTAL.
           IF BOOK-UNDERWRITING-NAME-CAP < 1
               IF BOOK-UNDERWRITING-NAME-PTR NOT = NULL
                   FREE BOOK-UNDERWRITING-NAME-PTR
               END-IF
               ALLOCATE 1 CHARACTERS RETURNING BOOK-UNDERWRITING-NAME-PTR
               SET ADDRESS OF BOOK-UNDERWRITING-NAME-BUF TO BOOK-UNDERWRITING-NAME-PTR
               COMPUTE BOOK-UNDERWRITING-NAME-CAP = 1
           END-IF.
           SET ADDRESS OF BOOK-UNDERWRITING-NAME-BUF TO BOOK-UNDERWRITING-NAME-PTR
           DISPLAY BOOK-UNDERWRITING-NAME-BUF(1:BOOK-UNDERWRITING-NAME-LEN).
           IF BOOK-CLAIMS-NAME-CAP < 1
               IF BOOK-CLAIMS-NAME-PTR NOT = NULL
                   FREE BOOK-CLAIMS-NAME-PTR
               END-IF
               ALLOCATE 1 CHARACTERS RETURNING BOOK-CLAIMS-NAME-PTR
               SET ADDRESS OF BOOK-CLAIMS-NAME-BUF TO BOOK-CLAIMS-NAME-PTR
               COMPUTE BOOK-CLAIMS-NAME-CAP = 1
           END-IF.
           SET ADDRESS OF BOOK-CLAIMS-NAME-BUF TO BOOK-CLAIMS-NAME-PTR
           DISPLAY BOOK-CLAIMS-NAME-BUF(1:BOOK-CLAIMS-NAME-LEN).
           DISPLAY "Active desks".
           DISPLAY ACTIVE-DESKS.
           DISPLAY "Imported total".
           DISPLAY IMPORTED-TOTAL.
           GOBACK.

       END PROGRAM SHOWCASE-PORTFOLIO.

