int title_length;
int note_length;
string title("POLICY SNAPSHOT");
string note(16);

void showcase_text()
{
    note = "clean base";
    display(title);
    title_length = title.len();
    display("Title chars");
    display(title_length);
    display(note);
    note_length = note.len();
    display("Note chars");
    display(note_length);
    return;
}
