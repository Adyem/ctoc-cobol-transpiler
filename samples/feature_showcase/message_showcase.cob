       IDENTIFICATION DIVISION.
       PROGRAM-ID. MAIN.
       ENVIRONMENT DIVISION.
       DATA DIVISION.
       WORKING-STORAGE SECTION.
       01 RESERVE-TARGET PIC S9(9) VALUE 600000.
       01 NET-PREMIUM PIC S9(9) VALUE 480000.
       01 SNAPSHOT-LOAD-POLICIES PIC S9(9).
       01 SNAPSHOT-LOAD-CLAIMS PIC S9(9).
       01 SNAPSHOT-LOAD-INVESTIGATIONS PIC S9(9).
       01 SNAPSHOT-LOAD-PAYOUT PIC S9(9).
       01 SNAPSHOT.
       05 SNAPSHOT-IDENTIFIER PIC S9(9).
       05 SNAPSHOT-POLICIES-IN-FORCE-VALUE PIC S9(9).
       05 SNAPSHOT-CLAIMS-REPORTED-VALUE PIC S9(9).
       05 SNAPSHOT-OPEN-INVESTIGATIONS-VALUE PIC S9(9).
       05 SNAPSHOT-CLAIM-PAYOUT-VALUE PIC S9(9).
       05 SNAPSHOT-LABEL.
       10 SNAPSHOT-LABEL-LEN PIC 9(4) COMP VALUE 0.
       10 SNAPSHOT-LABEL-BUF PIC X(16).
       01 PORTFOLIO.
       05 PORTFOLIO-PRIMARY.
       10 PORTFOLIO-PRIMARY-NAME.
       15 PORTFOLIO-PRIMARY-NAME-LEN PIC 9(4) COMP VALUE 0.
       15 PORTFOLIO-PRIMARY-NAME-BUF PIC X(16).
       10 PORTFOLIO-PRIMARY-ACTIVE PIC S9(9).
       05 PORTFOLIO-SECONDARY.
       10 PORTFOLIO-SECONDARY-NAME.
       15 PORTFOLIO-SECONDARY-NAME-LEN PIC 9(4) COMP VALUE 0.
       15 PORTFOLIO-SECONDARY-NAME-BUF PIC X(16).
       10 PORTFOLIO-SECONDARY-ACTIVE PIC S9(9).
       01 TITLE-LENGTH PIC S9(9).
       01 LITERAL-LENGTH PIC S9(9).
       01 POLICIES-TOTAL PIC S9(9).
       01 CLAIMS-TOTAL PIC S9(9).
       01 INVESTIGATIONS-TOTAL PIC S9(9).
       01 LOSS-RATIO-TOTAL PIC S9(9).
       01 CLAIM-DELTA-TOTAL PIC S9(9).
       01 RESERVE-GAP-TOTAL PIC S9(9).
       01 MODULE-COUNT PIC S9(9).
       01 SUMMARY-LENGTH PIC S9(9).
       01 SNAPSHOT-ID-TOTAL PIC S9(9).
       01 ARRAY-VALUE PIC S9(9).
       01 SCORES PIC S9(9) OCCURS 3 TIMES.
       01 SLOT PIC S9(9).
       01 POINTER-SCORE PIC S9(9).
       01 POINTER-RESULT PIC S9(9).
       01 ITEMS USAGE POINTER VALUE NULL.
       01 ROVER USAGE POINTER VALUE NULL.
       01 SCORE-HANDLE USAGE POINTER VALUE NULL.
       01 BUFFER USAGE POINTER VALUE NULL.
       01 LETTER PIC X(1).
       01 RAW USAGE POINTER VALUE NULL.
       01 CBLC-RETURN-PICK-SCORE USAGE POINTER VALUE NULL.
       01 MAIN-TITLE.
          05 MAIN-TITLE-LEN PIC 9(4) COMP VALUE 22.
          05 MAIN-TITLE-BUF PIC X(22).
       01 MAIN-SUMMARY.
          05 MAIN-SUMMARY-LEN PIC 9(4) COMP VALUE 32.
          05 MAIN-SUMMARY-BUF PIC X(32).
       01 CBLC-PTR-CURSOR USAGE POINTER VALUE NULL.
       01 CBLC-PTR-OFFSET PIC S9(9) VALUE 0.
       01 CBLC-PTR-CHAR BASED PIC X.
       01 CBLC-PTR-INT BASED PIC S9(9).
       PROCEDURE DIVISION.
       MAIN.
           COMPUTE SNAPSHOT-IDENTIFIER = 7.
           MOVE "RISK" TO SNAPSHOT-LABEL-BUF.
           MOVE 4 TO SNAPSHOT-LABEL-LEN.
           COMPUTE SNAPSHOT-POLICIES-IN-FORCE-VALUE = 0.
           COMPUTE SNAPSHOT-CLAIMS-REPORTED-VALUE = 0.
           COMPUTE SNAPSHOT-OPEN-INVESTIGATIONS-VALUE = 0.
           COMPUTE SNAPSHOT-CLAIM-PAYOUT-VALUE = 0.
           MOVE 0 TO MAIN-TITLE-LEN.
           MOVE SPACES TO MAIN-TITLE-BUF.
           MOVE "CBL-C FEATURE SHOWCASE" TO MAIN-TITLE-BUF.
           COMPUTE MAIN-TITLE-LEN = 22.
           MOVE 0 TO MAIN-SUMMARY-LEN.
           MOVE SPACES TO MAIN-SUMMARY-BUF.
           DISPLAY MAIN-TITLE-BUF(1:MAIN-TITLE-LEN).
           COMPUTE TITLE-LENGTH = MAIN-TITLE-LEN.
           DISPLAY "Title length".
           DISPLAY TITLE-LENGTH.
           COMPUTE LITERAL-LENGTH = 13.
           DISPLAY "Literal length".
           DISPLAY LITERAL-LENGTH.
           PERFORM PRINT-STAGE.
           DISPLAY SNAPSHOT-LABEL-BUF(1:SNAPSHOT-LABEL-LEN).
           COMPUTE SNAPSHOT-LOAD-POLICIES = 1250.
           COMPUTE SNAPSHOT-LOAD-CLAIMS = 32.
           COMPUTE SNAPSHOT-LOAD-INVESTIGATIONS = 5.
           COMPUTE SNAPSHOT-LOAD-PAYOUT = 72000.
           COMPUTE SNAPSHOT-POLICIES-IN-FORCE-VALUE = SNAPSHOT-LOAD-POLICIES.
           COMPUTE SNAPSHOT-CLAIMS-REPORTED-VALUE = SNAPSHOT-LOAD-CLAIMS.
           COMPUTE SNAPSHOT-OPEN-INVESTIGATIONS-VALUE = SNAPSHOT-LOAD-INVESTIGATIONS.
           COMPUTE SNAPSHOT-CLAIM-PAYOUT-VALUE = SNAPSHOT-LOAD-PAYOUT.
           COMPUTE POLICIES-TOTAL = SNAPSHOT-POLICIES-IN-FORCE-VALUE.
           COMPUTE CLAIMS-TOTAL = SNAPSHOT-CLAIMS-REPORTED-VALUE.
           COMPUTE INVESTIGATIONS-TOTAL = SNAPSHOT-OPEN-INVESTIGATIONS-VALUE.
           COMPUTE LOSS-RATIO-TOTAL = SNAPSHOT-CLAIM-PAYOUT-VALUE * 100 / NET-PREMIUM.
           COMPUTE CLAIM-DELTA-TOTAL = SNAPSHOT-CLAIMS-REPORTED-VALUE - SNAPSHOT-OPEN-INVESTIGATIONS-VALUE.
           COMPUTE RESERVE-GAP-TOTAL = RESERVE-TARGET - NET-PREMIUM.
           MOVE "UNDERWRITING" TO PORTFOLIO-PRIMARY-NAME-BUF.
           MOVE 12 TO PORTFOLIO-PRIMARY-NAME-LEN.
           COMPUTE PORTFOLIO-PRIMARY-ACTIVE = 1.
           MOVE "CLAIMS" TO PORTFOLIO-SECONDARY-NAME-BUF.
           MOVE 6 TO PORTFOLIO-SECONDARY-NAME-LEN.
           COMPUTE PORTFOLIO-SECONDARY-ACTIVE = 1.
           COMPUTE MODULE-COUNT = PORTFOLIO-PRIMARY-ACTIVE + PORTFOLIO-SECONDARY-ACTIVE.
           MOVE "UNDERWRITING + CLAIMS" TO MAIN-SUMMARY-BUF.
           MOVE 21 TO MAIN-SUMMARY-LEN.
           DISPLAY MAIN-SUMMARY-BUF(1:MAIN-SUMMARY-LEN).
           DISPLAY "Summary length".
           COMPUTE SUMMARY-LENGTH = MAIN-SUMMARY-LEN.
           DISPLAY SUMMARY-LENGTH.
           COMPUTE SCORES(1) = 7.
           COMPUTE SLOT = 1.
           COMPUTE SCORES(SLOT + 1) = 84.
           DISPLAY "Array value".
           COMPUTE ARRAY-VALUE = SCORES(SLOT + 1).
           DISPLAY ARRAY-VALUE.
           ALLOCATE 16 CHARACTERS RETURNING RAW.
           FREE RAW.
           ALLOCATE 12 CHARACTERS RETURNING ITEMS.
           SET CBLC-PTR-CURSOR TO ITEMS.
           SET ADDRESS OF CBLC-PTR-INT TO CBLC-PTR-CURSOR.
           COMPUTE CBLC-PTR-INT = 21.
           SET CBLC-PTR-CURSOR TO ITEMS.
           COMPUTE CBLC-PTR-OFFSET = 1 * 4.
           SET CBLC-PTR-CURSOR UP BY CBLC-PTR-OFFSET.
           SET ADDRESS OF CBLC-PTR-INT TO CBLC-PTR-CURSOR.
           COMPUTE CBLC-PTR-INT = 84.
           SET ROVER TO ITEMS.
           COMPUTE CBLC-PTR-OFFSET = 1 * 4.
           SET ROVER UP BY CBLC-PTR-OFFSET.
           SET CBLC-PTR-CURSOR TO ROVER.
           SET ADDRESS OF CBLC-PTR-INT TO CBLC-PTR-CURSOR.
           COMPUTE POINTER-RESULT = CBLC-PTR-INT.
           DISPLAY "Pointer arithmetic value".
           DISPLAY POINTER-RESULT.
           FREE ITEMS.
           ALLOCATE 4 CHARACTERS RETURNING BUFFER.
           COMPUTE SLOT = 1.
           SET CBLC-PTR-CURSOR TO BUFFER.
           COMPUTE CBLC-PTR-OFFSET = SLOT * 1.
           SET CBLC-PTR-CURSOR UP BY CBLC-PTR-OFFSET.
           SET ADDRESS OF CBLC-PTR-CHAR TO CBLC-PTR-CURSOR.
           MOVE "B" TO CBLC-PTR-CHAR.
           SET CBLC-PTR-CURSOR TO BUFFER.
           COMPUTE CBLC-PTR-OFFSET = SLOT * 1.
           SET CBLC-PTR-CURSOR UP BY CBLC-PTR-OFFSET.
           SET ADDRESS OF CBLC-PTR-CHAR TO CBLC-PTR-CURSOR.
           MOVE CBLC-PTR-CHAR TO LETTER.
           DISPLAY "Char pointer value".
           DISPLAY LETTER.
           FREE BUFFER.
           COMPUTE POINTER-SCORE = 41.
           PERFORM PICK-SCORE.
           SET SCORE-HANDLE TO CBLC-RETURN-PICK-SCORE.
           SET CBLC-PTR-CURSOR TO SCORE-HANDLE.
           SET ADDRESS OF CBLC-PTR-INT TO CBLC-PTR-CURSOR.
           COMPUTE POINTER-RESULT = CBLC-PTR-INT.
           DISPLAY "Pointer return value".
           DISPLAY POINTER-RESULT.
           DISPLAY PORTFOLIO-PRIMARY-NAME-BUF(1:PORTFOLIO-PRIMARY-NAME-LEN).
           DISPLAY PORTFOLIO-SECONDARY-NAME-BUF(1:PORTFOLIO-SECONDARY-NAME-LEN).
           DISPLAY "Module count".
           DISPLAY MODULE-COUNT.
           DISPLAY "Snapshot id".
           COMPUTE SNAPSHOT-ID-TOTAL = SNAPSHOT-IDENTIFIER.
           DISPLAY SNAPSHOT-ID-TOTAL.
           DISPLAY "Policies in force".
           DISPLAY POLICIES-TOTAL.
           DISPLAY "Claims reported".
           DISPLAY CLAIMS-TOTAL.
           DISPLAY "Open investigations".
           DISPLAY INVESTIGATIONS-TOTAL.
           DISPLAY "Loss ratio percent".
           DISPLAY LOSS-RATIO-TOTAL.
           DISPLAY "Claim clearance delta".
           DISPLAY CLAIM-DELTA-TOTAL.
           DISPLAY "Reserve target gap".
           DISPLAY RESERVE-GAP-TOTAL.
           DISPLAY "FEATURE SHOWCASE COMPLETE".
           MOVE 0 TO MAIN-SUMMARY-LEN.
           MOVE SPACES TO MAIN-SUMMARY-BUF.
           MOVE 0 TO MAIN-TITLE-LEN.
           MOVE SPACES TO MAIN-TITLE-BUF.
           STOP RUN.

       PRINT-STAGE.
           DISPLAY "Function call OK".

       PICK-SCORE.
           SET CBLC-RETURN-PICK-SCORE TO ADDRESS OF POINTER-SCORE.

       END PROGRAM MAIN.

