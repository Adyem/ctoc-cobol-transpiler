       IDENTIFICATION DIVISION.
       PROGRAM-ID. SHOWCASE-PORTFOLIO.
       ENVIRONMENT DIVISION.
       DATA DIVISION.
       WORKING-STORAGE SECTION.
       01 PORTFOLIO.
       05 PORTFOLIO-PRIMARY.
       10 PORTFOLIO-PRIMARY-NAME.
       15 PORTFOLIO-PRIMARY-NAME-LEN PIC 9(4) COMP VALUE 0.
       15 PORTFOLIO-PRIMARY-NAME-CAP PIC 9(4) COMP VALUE 0.
       15 PORTFOLIO-PRIMARY-NAME-PTR USAGE POINTER VALUE NULL.
       10 PORTFOLIO-PRIMARY-ACTIVE PIC S9(9).
       05 PORTFOLIO-SECONDARY.
       10 PORTFOLIO-SECONDARY-NAME.
       15 PORTFOLIO-SECONDARY-NAME-LEN PIC 9(4) COMP VALUE 0.
       15 PORTFOLIO-SECONDARY-NAME-CAP PIC 9(4) COMP VALUE 0.
       15 PORTFOLIO-SECONDARY-NAME-PTR USAGE POINTER VALUE NULL.
       10 PORTFOLIO-SECONDARY-ACTIVE PIC S9(9).
       01 PORTFOLIO-PRIMARY-NAME-BUF BASED PIC X(16).
       01 PORTFOLIO-SECONDARY-NAME-BUF BASED PIC X(16).
       01 MODULE-COUNT PIC S9(9).
       PROCEDURE DIVISION.
       SHOWCASE-PORTFOLIO.
           IF PORTFOLIO-PRIMARY-NAME-CAP < 12
               IF PORTFOLIO-PRIMARY-NAME-PTR NOT = NULL
                   FREE PORTFOLIO-PRIMARY-NAME-PTR
               END-IF
               ALLOCATE 12 CHARACTERS RETURNING PORTFOLIO-PRIMARY-NAME-PTR
               SET ADDRESS OF PORTFOLIO-PRIMARY-NAME-BUF TO PORTFOLIO-PRIMARY-NAME-PTR
               COMPUTE PORTFOLIO-PRIMARY-NAME-CAP = 12
           END-IF.
           SET ADDRESS OF PORTFOLIO-PRIMARY-NAME-BUF TO PORTFOLIO-PRIMARY-NAME-PTR
           MOVE "UNDERWRITING" TO PORTFOLIO-PRIMARY-NAME-BUF.
           MOVE 12 TO PORTFOLIO-PRIMARY-NAME-LEN.
           COMPUTE PORTFOLIO-PRIMARY-ACTIVE = 1.
           IF PORTFOLIO-SECONDARY-NAME-CAP < 6
               IF PORTFOLIO-SECONDARY-NAME-PTR NOT = NULL
                   FREE PORTFOLIO-SECONDARY-NAME-PTR
               END-IF
               ALLOCATE 6 CHARACTERS RETURNING PORTFOLIO-SECONDARY-NAME-PTR
               SET ADDRESS OF PORTFOLIO-SECONDARY-NAME-BUF TO PORTFOLIO-SECONDARY-NAME-PTR
               COMPUTE PORTFOLIO-SECONDARY-NAME-CAP = 6
           END-IF.
           SET ADDRESS OF PORTFOLIO-SECONDARY-NAME-BUF TO PORTFOLIO-SECONDARY-NAME-PTR
           MOVE "CLAIMS" TO PORTFOLIO-SECONDARY-NAME-BUF.
           MOVE 6 TO PORTFOLIO-SECONDARY-NAME-LEN.
           COMPUTE PORTFOLIO-SECONDARY-ACTIVE = 1.
           COMPUTE MODULE-COUNT = PORTFOLIO-PRIMARY-ACTIVE + PORTFOLIO-SECONDARY-ACTIVE.
           IF PORTFOLIO-PRIMARY-NAME-CAP < 1
               IF PORTFOLIO-PRIMARY-NAME-PTR NOT = NULL
                   FREE PORTFOLIO-PRIMARY-NAME-PTR
               END-IF
               ALLOCATE 1 CHARACTERS RETURNING PORTFOLIO-PRIMARY-NAME-PTR
               SET ADDRESS OF PORTFOLIO-PRIMARY-NAME-BUF TO PORTFOLIO-PRIMARY-NAME-PTR
               COMPUTE PORTFOLIO-PRIMARY-NAME-CAP = 1
           END-IF.
           SET ADDRESS OF PORTFOLIO-PRIMARY-NAME-BUF TO PORTFOLIO-PRIMARY-NAME-PTR
           DISPLAY PORTFOLIO-PRIMARY-NAME-BUF(1:PORTFOLIO-PRIMARY-NAME-LEN).
           IF PORTFOLIO-SECONDARY-NAME-CAP < 1
               IF PORTFOLIO-SECONDARY-NAME-PTR NOT = NULL
                   FREE PORTFOLIO-SECONDARY-NAME-PTR
               END-IF
               ALLOCATE 1 CHARACTERS RETURNING PORTFOLIO-SECONDARY-NAME-PTR
               SET ADDRESS OF PORTFOLIO-SECONDARY-NAME-BUF TO PORTFOLIO-SECONDARY-NAME-PTR
               COMPUTE PORTFOLIO-SECONDARY-NAME-CAP = 1
           END-IF.
           SET ADDRESS OF PORTFOLIO-SECONDARY-NAME-BUF TO PORTFOLIO-SECONDARY-NAME-PTR
           DISPLAY PORTFOLIO-SECONDARY-NAME-BUF(1:PORTFOLIO-SECONDARY-NAME-LEN).
           DISPLAY "Module count".
           DISPLAY MODULE-COUNT.
           GOBACK.

       END PROGRAM SHOWCASE-PORTFOLIO.
