       IDENTIFICATION DIVISION.
       PROGRAM-ID. MAIN.
       ENVIRONMENT DIVISION.
       DATA DIVISION.
       WORKING-STORAGE SECTION.
       01 UNDERWRITING.
       05 UNDERWRITING-NAME.
       10 UNDERWRITING-NAME-LEN PIC 9(4) COMP VALUE 0.
       10 UNDERWRITING-NAME-BUF PIC X(16).
       05 UNDERWRITING-ACTIVE PIC S9(9).
       01 CLAIMS.
       05 CLAIMS-NAME.
       10 CLAIMS-NAME-LEN PIC 9(4) COMP VALUE 0.
       10 CLAIMS-NAME-BUF PIC X(16).
       05 CLAIMS-ACTIVE PIC S9(9).
       01 REPORTING-MODULE.
       05 REPORTING-MODULE-NAME.
       10 REPORTING-MODULE-NAME-LEN PIC 9(4) COMP VALUE 0.
       10 REPORTING-MODULE-NAME-BUF PIC X(16).
       05 REPORTING-MODULE-ACTIVE PIC S9(9).
       01 MODULE-COUNT PIC S9(9).
       01 SUMMARY-LENGTH PIC S9(9).
       01 MAIN-BANNER.
          05 MAIN-BANNER-LEN PIC 9(4) COMP VALUE 24.
          05 MAIN-BANNER-BUF PIC X(24).
       01 MAIN-SUMMARY.
          05 MAIN-SUMMARY-LEN PIC 9(4) COMP VALUE 32.
          05 MAIN-SUMMARY-BUF PIC X(32).
       PROCEDURE DIVISION.
MAIN.
           MOVE 0 TO MAIN-BANNER-LEN.
           MOVE SPACES TO MAIN-BANNER-BUF.
           MOVE 0 TO MAIN-SUMMARY-LEN.
           MOVE SPACES TO MAIN-SUMMARY-BUF.
           MOVE "RISK MODULES LIVE" TO MAIN-BANNER-BUF.
           MOVE 17 TO MAIN-BANNER-LEN.
           DISPLAY MAIN-BANNER-BUF(1:MAIN-BANNER-LEN).
           MOVE "UNDERWRITING" TO UNDERWRITING-NAME-BUF.
           MOVE 12 TO UNDERWRITING-NAME-LEN.
           COMPUTE UNDERWRITING-ACTIVE = 1.
           MOVE "CLAIMS" TO CLAIMS-NAME-BUF.
           MOVE 6 TO CLAIMS-NAME-LEN.
           COMPUTE CLAIMS-ACTIVE = 1.
           MOVE "REPORTING" TO REPORTING-MODULE-NAME-BUF.
           MOVE 9 TO REPORTING-MODULE-NAME-LEN.
           COMPUTE REPORTING-MODULE-ACTIVE = 1.
           MOVE "UNDERWRITING + CLAIMS" TO MAIN-SUMMARY-BUF.
           MOVE 21 TO MAIN-SUMMARY-LEN.
           DISPLAY MAIN-SUMMARY-BUF(1:MAIN-SUMMARY-LEN).
           COMPUTE SUMMARY-LENGTH = MAIN-SUMMARY-LEN.
           DISPLAY "Summary length".
           DISPLAY SUMMARY-LENGTH.
           DISPLAY UNDERWRITING-NAME-BUF(1:UNDERWRITING-NAME-LEN).
           DISPLAY CLAIMS-NAME-BUF(1:CLAIMS-NAME-LEN).
           DISPLAY REPORTING-MODULE-NAME-BUF(1:REPORTING-MODULE-NAME-LEN).
           COMPUTE MODULE-COUNT = UNDERWRITING-ACTIVE + CLAIMS-ACTIVE + REPORTING-MODULE-ACTIVE.
           DISPLAY "Module count".
           DISPLAY MODULE-COUNT.
           MOVE 0 TO MAIN-SUMMARY-LEN.
           MOVE SPACES TO MAIN-SUMMARY-BUF.
           MOVE 0 TO MAIN-BANNER-LEN.
           MOVE SPACES TO MAIN-BANNER-BUF.
           STOP RUN.

       END PROGRAM MAIN.

